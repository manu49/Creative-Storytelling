# Copy to backend/.env and set your values
# Frontend vars (NEXT_PUBLIC_*) can go in frontend/.env.local

# Anthropic API (required)
ANTHROPIC_API_KEY=sk-ant-...

# Database (path relative to backend/)
DATABASE_URL=sqlite+aiosqlite:///./data/creative_storytelling.db

# RAG
FAISS_INDEX_PATH=./data/faiss_index
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM Models
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-4-6

# Agent Worker
AGENT_POLL_INTERVAL_SECONDS=3.0
AGENT_MAX_CONCURRENT_TASKS=2

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# WebSocket
WS_HEARTBEAT_INTERVAL=30

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
